    "body_content": "<!doctype html>\n\n\n\n<header class=\"site-header\">\n  <div class=\"header-inner\">\n    <a href=\"/\" class=\"header-logo\">Cornwall Waste Clearance</a>\n    \n    <div class=\"header-cta\">\n      <a href=\"tel:07347300788\" class=\"header-phone\">\ud83d\udcde 07347 300788</a>\n      <a href=\"/contact-us/\" class=\"header-btn\">Free Quote</a>\n    </div>\n  </div>\n</header>\n<div class=\"hero-img\"></div>\n<h1 class=\"page-h1\">Rubbish Clearance Cornwall | Based in Cornwall</h1>\n\n<div class=\"trust-banner\">\n  <div class=\"trust-item\">\u2764\ufe0f Local Family Business</div>\n  <div class=\"trust-item\">\u2b50 123 Five-Star Reviews</div>\n  <div class=\"trust-item\">\u2705 134 Clearances This Year</div>\n  <div class=\"trust-item\">\ud83c\udfc6 14+ Years Experience</div>\n  <div class=\"trust-item\">\u267b\ufe0f Environment Agency Registered</div>\n  <div class=\"trust-item\">\ud83c\udf3f Eco-Friendly & Recycling</div>\n  <div class=\"trust-item\">\ud83c\udf81 Charity Donations Where Possible</div>\n  <div class=\"trust-item\">\ud83d\udcde Free Quotes \u2014 No Obligation</div>\n  <div class=\"trust-item\">\ud83d\udd50 Mon\u2013Sat 7am\u20137pm</div>\n</div>\n<div class=\"container\" style=\"padding:0 0 8px 0\"><div class=\"before-after-gallery\">\n        <div class=\"before-after-item\">\n          <img src=\"/assets/images/Before Rubbish Removal.webp\" alt=\"Before rubbish removal by Cornwall Waste Clearance\" loading=\"lazy\" />\n          <span class=\"before-after-label\">Before</span>\n        </div>\n        <div class=\"before-after-item\">\n          <img src=\"/assets/images/After Rubbish Removal.webp\" alt=\"After rubbish removal by Cornwall Waste Clearance\" loading=\"lazy\" />\n          <span class=\"before-after-label\">After</span>\n        </div>\n      </div></div>\n<h2>Fast Removal. No Skip. No Fly-Tipping. Free Quote.</h2>\n<section class=\"content-section\">\n  <div class=\"container content-narrow\">\n\n    <div class=\"content-block\">\n      <p>Our rubbish clearance service covers all of Cornwall. We remove household waste, garden rubbish, commercial waste and general clutter quickly and responsibly. All waste is taken to licensed facilities \u2014 we never fly-tip.</p>\n      <div class=\"cta-buttons\">\n        <a href=\"tel:07347300788\" class=\"btn btn-green\">&#128222; Call: 07347 300788</a>\n        <a href=\"/contact-us/\" class=\"btn btn-dark\">&#9993;&#65039; Get a Free Quote</a>\n      </div>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>What We Clear</h2>\n      <ul>\n        <li>Household rubbish and general waste</li>\n        <li>Garden waste and green cuttings</li>\n        <li>Old furniture and appliances</li>\n        <li>Scrap metal</li>\n        <li>Builder's rubble and materials</li>\n        <li>Commercial and office waste</li>\n      </ul>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>Areas We Cover in Cornwall</h2>\n      <p>We provide rubbish clearance cornwall services across all of Cornwall. Select your area below:</p>\n      <div class=\"location-grid\">\n        <a href=\"/rubbish-clearance-ashton/\" class=\"loc-link\">Ashton</a>\n        <a href=\"/rubbish-clearance-blackwater/\" class=\"loc-link\">Blackwater</a>\n        <a href=\"/rubbish-clearance-bodinnick/\" class=\"loc-link\">Bodinnick</a>\n        <a href=\"/rubbish-clearance-bodmin/\" class=\"loc-link\">Bodmin</a>\n        <a href=\"/rubbish-clearance-boscastle/\" class=\"loc-link\">Boscastle</a>\n        <a href=\"/rubbish-clearance-breage/\" class=\"loc-link\">Breage</a>\n        <a href=\"/rubbish-clearance-bude/\" class=\"loc-link\">Bude</a>\n        <a href=\"/rubbish-clearance-budock-water/\" class=\"loc-link\">Budock Water</a>\n        <a href=\"/rubbish-clearance-bugle/\" class=\"loc-link\">Bugle</a>\n        <a href=\"/rubbish-clearance-callington/\" class=\"loc-link\">Callington</a>\n        <a href=\"/rubbish-clearance-calstock/\" class=\"loc-link\">Calstock</a>\n        <a href=\"/rubbish-clearance-camborne/\" class=\"loc-link\">Camborne</a>\n        <a href=\"/rubbish-clearance-camelford/\" class=\"loc-link\">Camelford</a>\n        <a href=\"/rubbish-clearance-canons-town/\" class=\"loc-link\">Canons Town</a>\n        <a href=\"/rubbish-clearance-carbis-bay/\" class=\"loc-link\">Carbis Bay</a>\n        <a href=\"/rubbish-clearance-carey-park/\" class=\"loc-link\">Carey Park</a>\n        <a href=\"/rubbish-clearance-carharrack/\" class=\"loc-link\">Carharrack</a>\n        <a href=\"/rubbish-clearance-carlyon-bay/\" class=\"loc-link\">Carlyon Bay</a>\n        <a href=\"/rubbish-clearance-carnon-downs/\" class=\"loc-link\">Carnon Downs</a>\n        <a href=\"/rubbish-clearance-cawsand/\" class=\"loc-link\">Cawsand</a>\n        <a href=\"/rubbish-clearance-chacewater/\" class=\"loc-link\">Chacewater</a>\n        <a href=\"/rubbish-clearance-connor-downs/\" class=\"loc-link\">Connor Downs</a>\n        <a href=\"/rubbish-clearance-constantine/\" class=\"loc-link\">Constantine</a>\n        <a href=\"/rubbish-clearance-cornwall/\" class=\"loc-link\">Cornwall</a>\n        <a href=\"/rubbish-clearance-crantock/\" class=\"loc-link\">Crantock</a>\n        <a href=\"/rubbish-clearance-crowlas/\" class=\"loc-link\">Crowlas</a>\n        <a href=\"/rubbish-clearance-cubert/\" class=\"loc-link\">Cubert</a>\n        <a href=\"/rubbish-clearance-delabole/\" class=\"loc-link\">Delabole</a>\n        <a href=\"/rubbish-clearance-devoran/\" class=\"loc-link\">Devoran</a>\n        <a href=\"/rubbish-clearance-dobwalls/\" class=\"loc-link\">Dobwalls</a>\n        <a href=\"/rubbish-clearance-downderry/\" class=\"loc-link\">Downderry</a>\n        <a href=\"/rubbish-clearance-duporth/\" class=\"loc-link\">Duporth</a>\n        <a href=\"/rubbish-clearance-egloshayle/\" class=\"loc-link\">Egloshayle</a>\n        <a href=\"/rubbish-clearance-falmouth/\" class=\"loc-link\">Falmouth</a>\n        <a href=\"/rubbish-clearance-flushing/\" cl