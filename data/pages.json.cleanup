hen</a>\n        <a href=\"/garden-clearance-st-teath/\" class=\"loc-link\">St Teath</a>\n        <a href=\"/garden-clearance-st-tudy/\" class=\"loc-link\">St Tudy</a>\n        <a href=\"/garden-clearance-stenalees/\" class=\"loc-link\">Stenalees</a>\n        <a href=\"/garden-clearance-sticker/\" class=\"loc-link\">Sticker</a>\n        <a href=\"/garden-clearance-stithians/\" class=\"loc-link\">Stithians</a>\n        <a href=\"/garden-clearance-stratton/\" class=\"loc-link\">Stratton</a>\n        <a href=\"/garden-clearance-summercourt/\" class=\"loc-link\">Summercourt</a>\n        <a href=\"/garden-clearance-threemilestone/\" class=\"loc-link\">Threemilestone</a>\n        <a href=\"/garden-clearance-tintagel/\" class=\"loc-link\">Tintagel</a>\n        <a href=\"/garden-clearance-tolvaddon/\" class=\"loc-link\">Tolvaddon</a>\n        <a href=\"/garden-clearance-torpoint/\" class=\"loc-link\">Torpoint</a>\n        <a href=\"/garden-clearance-tregony/\" class=\"loc-link\">Tregony</a>\n        <a href=\"/garden-clearance-tresillian/\" class=\"loc-link\">Tresillian</a>\n        <a href=\"/garden-clearance-trewoon/\" class=\"loc-link\">Trewoon</a>\n        <a href=\"/garden-clearance-troon/\" class=\"loc-link\">Troon</a>\n        <a href=\"/garden-clearance-truro/\" class=\"loc-link\">Truro</a>\n        <a href=\"/garden-clearance-tywardreath/\" class=\"loc-link\">Tywardreath</a>\n        <a href=\"/garden-clearance-wadebridge/\" class=\"loc-link\">Wadebridge</a>\n        <a href=\"/garden-clearance-week-st-mary/\" class=\"loc-link\">Week St Mary</a>\n        <a href=\"/garden-clearance-withnoe/\" class=\"loc-link\">Withnoe</a>\n      </div>\n    </div>\n\n  </div>\n</section>\n\n\n<a href=\"/contact-us/\" class=\"quote-now-btn\" aria-label=\"Get a free quote from Cornwall Waste Clearance\">Free Quote</a>\n<a href=\"tel:07347300788\" class=\"call-now-btn\" aria-label=\"Call Cornwall Waste Clearance now\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"white\"><path d=\"M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z\"/></svg></a>\n<script src=\"/assets/js/main.js\"></script>",
