[
  {
    "slug": "about-us",
    "title": "About Us | Cornwall Waste Clearance",
    "body_content": "<!doctype html>\n\n\n\n<header class=\"site-header\">\n  <div class=\"header-inner\">\n    <a href=\"/\" class=\"header-logo\">Cornwall Waste Clearance</a>\n    \n    <div class=\"header-cta\">\n      <a href=\"tel:07347300788\" class=\"header-phone\">\ud83d\udcde 07347 300788</a>\n      <a href=\"/contact-us/\" class=\"header-btn\">Free Quote</a>\n    </div>\n  </div>\n</header>\n<div class=\"hero-img\"></div>\n<h1 class=\"page-h1\">About Us | Cornwall Waste Clearance</h1>\n\n<section class=\"content-section\">\n  <div class=\"container\">\n\n    <div class=\"content-block\">\n      <h2>Who We Are</h2>\n      <p>Cornwall Waste Clearance is a family-run property clearance company based in Cornwall. We provide domestic, commercial and specialist clearance services to customers right across the county \u2014 from Launceston to Land's End.</p>\n      <p>We're proud to be a fully licensed waste carrier, operating in full compliance with the Environment Agency. Every load we collect is handled responsibly \u2014 with as much as possible recycled, donated to charity, or diverted from landfill.</p>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>What We Do</h2>\n      <p>Whether you need a single room cleared or an entire commercial premises, we have the team, the vehicles and the experience to get the job done efficiently and with care.</p>\n      <ul>\n        <li>House &amp; flat clearance</li>\n        <li>Garage, attic &amp; loft clearance</li>\n        <li>Garden clearance</li>\n        <li>Bereavement &amp; probate clearance</li>\n        <li>Hoarder property clearance</li>\n        <li>Office, warehouse &amp; commercial clearance</li>\n      </ul>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>Our Approach</h2>\n      <p>We understand that clearance jobs \u2014 especially bereavement or hoarder clearances \u2014 can be emotionally difficult. Our team works with sensitivity and discretion at every step.</p>\n      <p>We're fully insured, punctual, and transparent about pricing. No hidden fees, no surprises.</p>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>Operating Hours</h2>\n      <p><strong>Monday \u2013 Saturday:</strong> 7:00am \u2013 7:00pm<br>\n      <strong>Sunday:</strong> Closed</p>\n    </div>\n\n    <div class=\"cta-block\">\n      <h2>Get a Free Quote</h2>\n      <p>Call us on <a href=\"tel:07347300788\"><strong>07347 300788</strong></a> or use our <a href=\"/contact-us/\">contact form</a> to request a free, no-obligation quote.</p>\n    </div>\n\n  </div>\n</section>\n\n\n<a href=\"/contact-us/\" class=\"quote-now-btn\" aria-label=\"Get a free quote from Cornwall Waste Clearance\">Free Quote</a>\n<a href=\"tel:07347300788\" class=\"call-now-btn\" aria-label=\"Call Cornwall Waste Clearance now\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"white\"><path d=\"M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z\"/></svg></a>\n<script src=\"/assets/js/main.js\"></script>",
    "description": "Learn about Cornwall Waste Clearance \u2014 a trusted local team providing house, garden, garage and commercial clearance services across Cornwall."
  },
  {
    "slug": "ashton",
    "title": "Man and Van Rubbish Clearance in Ashton | Fast & Reliable | 07347 300788",
    "body_content": "<section class=\"content-section\">\n  <div class=\"container content-narrow\">\n\n    <div class=\"content-block\">\n      <div class=\"trust-banner\">\n  <div class=\"trust-item\">\u2764\ufe0f Local Family Business</div>\n  <div class=\"trust-item\">\u2b50 123 Five-Star Reviews</div>\n  <div class=\"trust-item\">\u2705 134 Clearances This Year</div>\n  <div class=\"trust-item\">\ud83c\udfc6 14+ Years Experience</div>\n  <div class=\"trust-item\">\u267b\ufe0f Environment Agency Registered</div>\n  <div class=\"trust-item\">\ud83c\udf3f Eco-Friendly & Recycling</div>\n  <div class=\"trust-item\">\ud83c\udf81 Charity Donations Where Possible</div>\n  <div class=\"trust-item\">\ud83d\udcde Free Quotes \u2014 No Obligation</div>\n  <div class=\"trust-item\">\ud83d\udd50 Mon\u2013Sat 7am\u20137pm</div>\n</div>\n<p class=\"location-intro\"></p>\n\n<h2>Fast Removal. No Skip. No Fly-Tipping. Free Quote.</h2>\n      <p>Cornwall Waste Clearance provides fast, affordable rubbish clearance services in Ashton, Cornwall. Whether it is a single bulky item, a garage full of junk, or a complete property load, our team collects everything, sorts it responsibly, and leaves your space clear \u2014 often within days of your call.</p>\n      <p>We are a fully licensed waste carrier registered with the Environment Agency. Nothing is fly-tipped. All waste is taken to licensed facilities, with as much recycled or donated as possible.</p>\n      <div class=\"cta-buttons\">\n        <a href=\"tel:07347300788\" class=\"btn btn-green\">&#128222; Call: 07347 300788</a>\n        <a href=\"#quote\" class=\"btn btn-dark\">&#9993;&#65039; Get a Free Quote</a>\n      </div>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>Why Not Just Hire a Skip in Ashton?</h2>\n      <ul>\n        <li><strong>No permit needed</strong> \u2014 skips on public roads require a council permit. We drive away with everything.</li>\n        <li><strong>No labour</strong> \u2014 you fill a skip yourself. We do all the lifting and carrying for you.</li>\n        <li><strong>No wait</strong> \u2014 skip hire can take days to arrange and collect. We are often available same week.</li>\n        <li><strong>No restrictions</strong> \u2014 skips have prohibited items. We handle most things skips will not take.</li>\n        <li><strong>No eyesore</strong> \u2014 a skip sits outside your property for days. We arrive, load and go.</li>\n      </ul>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>What We Accept</h2>\n      <ul>\n        <li>Household furniture and white goods</li>\n        <li>Garden waste \u2014 green waste, soil, rubble in small quantities</li>\n        <li>General household junk and clutter</li>\n        <li>Electrical items and appliances</li>\n        <li>Scrap metal</li>\n        <li>Mattresses and soft furnishings</li>\n        <li>DIY waste \u2014 timber, plasterboard, tiles</li>\n        <li>Commercial rubbish \u2014 offices, shops, small businesses</li>\n      </ul>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>What We Cannot Take</h2>\n      <ul>\n        <li>Asbestos (requires specialist licensed contractor)</li>\n        <li>Clinical or medical waste</li>\n        <li>Chemicals, solvents or pesticides in large quantities</li>\n        <li>Firearms or ammunition</li>\n      </ul>\n      <p>If you are unsure whether we can take something, just call us on 07347 300788 and we will advise.</p>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>Pricing Guide for Ashton</h2>\n      <p>Prices are based on the volume of waste loaded onto our vehicle:</p>\n      <ul>\n        <li>Minimum load (a few items): <strong>from \u00a360</strong></li>\n        <li>Quarter load: <strong>\u00a3100\u2013\u00a3150</strong></li>\n        <li>Half load: <strong>\u00a3150\u2013\u00a3250</strong></li>\n        <li>Full load: <strong>\u00a3300\u2013\u00a3500</strong></li>\n        <li>Multiple loads / large clearances: <strong>POA</strong></li>\n      </ul>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>Frequently Asked Questions</h2>\n      <div class=\"faq-item\">\n        <strong>Can you collect rubbish the same day in Ashton?</strong>\n        <p>We aim to offer same-week collection across Cornwall. Same-day availability depends on our schedule \u2014 call 07347 300788 and we will do our best.</p>\n      </div>\n      <div class=\"faq-item\">\n        <strong>Do I need to bag the rubbish before you arrive?</strong>\n        <p>No \u2014 you do not need to bag, sort or move anything. Our team carries everything from wherever it is in the property.</p>\n      </div>\n      <div class=\"faq-item\">\n        <strong>Can you collect mixed loads \u2014 different types of waste together?</strong>\n        <p>Yes \u2014 mixed loads are no problem. We sort everything ourselves at our facility to ensure responsible disposal and maximum recycling.</p>\n      </div>\n      <div class=\"faq-item\">\n        <strong>Do you collect commercial rubbish from businesses in Ashton?</strong>\n        <p>Yes \u2014 we collect rubbish from offices, shops, warehouses and other commercial premises. Call us for a tailored quote.</p>\n      </div>\n      <div class=\"faq-item\">\n        <strong>Are you a licensed waste carrier?</strong>\n        <p>Yes. Cornwall Waste Clearance is fully registered with the Environment Agency. You will never be held liable for illegally disposed waste when you use our service.</p>\n      </div>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>More Clearance Services in Ashton</h2>\n      <div class=\"location-grid\">\n        <a href=\"/house-clearance-ashton/\" class=\"loc-link\">\ud83c\udfe1 House Clearance</a>\n        <a href=\"/garage-shed-clearance-ashton/\" class=\"loc-link\">\ud83d\ude97 Garage & Shed Clearance</a>\n        <a href=\"/attic-clearance-ashton/\" class=\"loc-link\">\ud83c\udfe0 Attic Clearance</a>\n        <a href=\"/bereavement-probate-clearance-ashton/\" class=\"loc-link\">\u26b1\ufe0f Bereavement & Probate Clearance</a>\n        <a href=\"/hoarder-clearance-ashton/\" class=\"loc-link\">\ud83c\udfe0 Hoarder Clearance</a>\n      </div>\n    </div>\n\n    <div class=\"content-block\">\n      <div class=\"map-wrapper\">\n        <iframe src=\"https://maps.google.com/maps?q=Ashton+Cornwall&output=embed\"\n          width=\"100%\" height=\"300\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\"></iframe>\n      </div>\n    </div>\n\n    <div id=\"quote\" class=\"content-block\">\n      <h2>Request a Free Quote in Ashton</h2>\n      <form method=\"POST\" action=\"/send.php\">\n        <div class=\"form-row\">\n          <label for=\"first-name\">First Name *</label>\n          <input type=\"text\" id=\"first-name\" name=\"first-name\" required>\n        </div>\n        <div class=\"form-row\">\n          <label for=\"surname\">Surname *</label>\n          <input type=\"text\" id=\"surname\" name=\"surname\" required>\n        </div>\n        <div class=\"form-row\">\n          <label for=\"telephone\">Telephone *</label>\n          <input type=\"tel\" id=\"telephone\" name=\"telephone\" required>\n        </div>\n        <div class=\"form-row\">\n          <label for=\"postcode\">Postcode *</label>\n          <input type=\"text\" id=\"postcode\" name=\"postcode\" required>\n        </div>\n        <div class=\"form-row\">\n          <label for=\"clearance-type\">Clearance Type *</label>\n          <select id=\"clearance-type\" name=\"clearance-type\" required>\n            <option value=\"\">Please select...</option>\n            <option value=\"House/Flat/Bungalow\">House / Flat / Bungalow</option>\n            <option value=\"Garage/Garden/Shed\">Garage / Garden / Shed</option>\n            <option value=\"Attic/Loft\">Attic / Loft</option>\n            <option value=\"Bereavement/Probate\">Bereavement / Probate</option>\n            <option value=\"Hoarder\">Hoarder Property</option>\n            <option value=\"Commercial/Industrial\">Commercial / Industrial</option>\n          </select>\n        </div>\n        <div class=\"form-row\">\n          <label for=\"message\">Message</label>\n          <textarea id=\"message\" name=\"message\" rows=\"4\"></textarea>\n        </div>\n        <button type=\"submit\" class=\"btn-primary\">Send Enquiry</button>\n      </form>\n    </div>\n\n  </div>\n<div class=\"nearby-locations\">\n  <h3>Also Serving Nearby Areas</h3>\n  <div class=\"nearby-pills\">\n<span class=\"nearby-pill\">Exeter</span>\n<span class=\"nearby-pill\">Chudleigh</span>\n<span class=\"nearby-pill\">Christow</span>\n  </div>\n</div>\n</section>",
    "description": "Man and van rubbish removals in Ashton \u2014 fast and reliable. Save time and money on your waste disposal and recycling needs. Call 07347 300788 Monday to Saturday 7am to 7pm."
  },
  {
    "slug": "attic-clearance",
    "title": "Attic & Loft Clearance Cornwall | Based in Cornwall",
    "body_content": "<!doctype html>\n\n\n\n<header class=\"site-header\">\n  <div class=\"header-inner\">\n    <a href=\"/\" class=\"header-logo\">Cornwall Waste Clearance</a>\n    \n    <div class=\"header-cta\">\n      <a href=\"tel:07347300788\" class=\"header-phone\">\ud83d\udcde 07347 300788</a>\n      <a href=\"/contact-us/\" class=\"header-btn\">Free Quote</a>\n    </div>\n  </div>\n</header>\n<div class=\"hero-img\"></div>\n<h1 class=\"page-h1\">Attic & Loft Clearance Cornwall | Based in Cornwall</h1>\n\n<div class=\"trust-banner\">\n  <div class=\"trust-item\">\u2764\ufe0f Local Family Business</div>\n  <div class=\"trust-item\">\u2b50 123 Five-Star Reviews</div>\n  <div class=\"trust-item\">\u2705 134 Clearances This Year</div>\n  <div class=\"trust-item\">\ud83c\udfc6 14+ Years Experience</div>\n  <div class=\"trust-item\">\u267b\ufe0f Environment Agency Registered</div>\n  <div class=\"trust-item\">\ud83c\udf3f Eco-Friendly & Recycling</div>\n  <div class=\"trust-item\">\ud83c\udf81 Charity Donations Where Possible</div>\n  <div class=\"trust-item\">\ud83d\udcde Free Quotes \u2014 No Obligation</div>\n  <div class=\"trust-item\">\ud83d\udd50 Mon\u2013Sat 7am\u20137pm</div>\n</div>\n<div class=\"container\" style=\"padding:0 0 8px 0\"><div class=\"before-after-gallery\">\n        <div class=\"before-after-item\">\n          <img src=\"/assets/images/Before Rubbish Removal.webp\" alt=\"Before rubbish removal by Cornwall Waste Clearance\" loading=\"lazy\" />\n          <span class=\"before-after-label\">Before</span>\n        </div>\n        <div class=\"before-after-item\">\n          <img src=\"/assets/images/After Rubbish Removal.webp\" alt=\"After rubbish removal by Cornwall Waste Clearance\" loading=\"lazy\" />\n          <span class=\"before-after-label\">After</span>\n        </div>\n      </div></div>\n<h2>Safe, Insured Loft Clearance \u2014 No Ladder Needed.</h2>\n<section class=\"content-section\">\n  <div class=\"container content-narrow\">\n\n    <div class=\"content-block\">\n      <p>Loft and attic spaces fill up over the years. Cornwall Waste Clearance provides safe, efficient attic and loft clearance services across Cornwall. Our team takes care of everything from access to removal and responsible disposal.</p>\n      <div class=\"cta-buttons\">\n        <a href=\"tel:07347300788\" class=\"btn btn-green\">&#128222; Call: 07347 300788</a>\n        <a href=\"/contact-us/\" class=\"btn btn-dark\">&#9993;&#65039; Get a Free Quote</a>\n      </div>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>What We Clear</h2>\n      <ul>\n        <li>Old furniture and stored items</li>\n        <li>Boxes and bags</li>\n        <li>Vintage and antique items</li>\n        <li>Clothing and textiles</li>\n        <li>Old electronics and appliances</li>\n        <li>General accumulated storage</li>\n      </ul>\n    </div>\n\n    <div class=\"content-block\">\n      <h2>Areas We Cover in Cornwall</h2>\n      <p>We provide attic & loft clearance cornwall services across all of Cornwall. Select your area below:</p>\n      <div class=\"location-grid\">\n        <a href=\"/attic-clearance-ashton/\" class=\"loc-link\">Ashton</a>\n        <a href=\"/attic-clearance-blackwater/\" class=\"loc-link\">Blackwater</a>\n        <a href=\"/attic-clearance-bodinnick/\" class=\"loc-link\">Bodinnick</a>\n        <a href=\"/attic-clearance-bodmin/\" class=\"loc-link\">Bodmin</a>\n        <a href=\"/attic-clearance-boscastle/\" class=\"loc-link\">Boscastle</a>\n        <a href=\"/attic-clearance-breage/\" class=\"loc-link\">Breage</a>\n        <a href=\"/attic-clearance-bude/\" class=\"loc-link\">Bude</a>\n        <a href=\"/attic-clearance-budock-water/\" class=\"loc-link\">Budock Water</a>\n        <a href=\"/attic-clearance-bugle/\" class=\"loc-link\">Bugle</a>\n        <a href=\"/attic-clearance-callington/\" class=\"loc-link\">Callington</a>\n        <a href=\"/attic-clearance-calstock/\" class=\"loc-link\">Calstock</a>\n        <a href=\"/attic-clearance-camborne/\" class=\"loc-link\">Camborne</a>\n        <a href=\"/attic-clearance-camelford/\" class=\"loc-link\">Camelford</a>\n        <a href=\"/attic-clearance-canons-town/\" class=\"loc-link\">Canons Town</a>\n        <a href=\"/attic-clearance-carbis-bay/\" class=\"loc-link\">Carbis Bay</a>\n        <a href=\"/attic-clearance-carey-park/\" class=\"loc-link\">Carey Park</a>\n        <a href=\"/attic-clearance-carharrack/\" class=\"loc-link\">Carharrack</a>\n        <a href=\"/attic-clearance-carlyon-bay/\" class=\"loc-link\">Carlyon Bay</a>\n        <a href=\"/attic-clearance-carnon-downs/\" class=\"loc-link\">Carnon Downs</a>\n        <a href=\"/attic-clearance-cawsand/\" class=\"loc-link\">Cawsand</a>\n        <a href=\"/attic-clearance-chacewater/\" class=\"loc-link\">Chacewater</a>\n        <a href=\"/attic-clearance-connor-downs/\" class=\"loc-link\">Connor Downs</a>\n        <a href=\"/attic-clearance-constantine/\" class=\"loc-link\">Constantine</a>\n        <a href=\"/attic-clearance-cornwall/\" class=\"loc-link\">Cornwall</a>\n        <a href=\"/attic-clearance-crantock/\" class=\"loc-link\">Crantock</a>\n        <a href=\"/attic-clearance-crowlas/\" class=\"loc-link\">Crowlas</a>\n        <a href=\"/attic-clearance-cubert/\" class=\"loc-link\">Cubert</a>\n        <a href=\"/attic-clearance-delabole/\" class=\"loc-link\">Delabole</a>\n        <a href=\"/attic-clearance-devoran/\" class=\"loc-link\">Devoran</a>\n        <a href=\"/attic-clearance-dobwalls/\" class=\"loc-link\">Dobwalls</a>\n        <a href=\"/attic-clearance-downderry/\" class=\"loc-link\">Downderry</a>\n        <a href=\"/attic-clearance-duporth/\" class=\"loc-link\">Duporth</a>\n        <a href=\"/attic-clearance-egloshayle/\" class=\"loc-link\">Egloshayle</a>\n        <a href=\"/attic-clearance-falmouth/\" class=\"loc-link\">Falmouth</a>\n        <a href=\"/attic-clearance-flushing/\" class=\"loc-link\">Flushing</a>\n        <a href=\"/attic-clearance-four-lanes/\" class=\"loc-link\">Four Lanes</a>\n        <a href=\"/attic-clearance-fowey/\" class=\"loc-link\">Fowey</a>\n        <a href=\"/attic-clearance-foxhole/\" class=\"loc-link\">Foxhole</a>\n        <a href=\"/attic-clearance-fraddon/\" class=\"loc-link\">Fraddon</a>\n        <a href=\"/attic-clearance-goldsithney/\" class=\"loc-link\">Goldsithney</a>\n        <a href=\"/attic-clearance-goonhavern/\" class=\"loc-link\">Goonhavern</a>\n        <a href=\"/attic-clearance-gorran-haven/\" class=\"loc-link\">Gorran Haven</a>\n        <a href=\"/attic-clearance-grampound/\" class=\"loc-link\">Grampound</a>\n        <a href=\"/attic-clearance-grampound-road/\" class=\"loc-link\">Grampound Road</a>\n        <a href=\"/attic-clearance-gunnislake/\" class=\"loc-link\">Gunnislake</a>\n        <a href=\"/attic-clearance-hannafore/\" class=\"loc-link\">Hannafore</a>\n        <a href=\"/attic-clearance-hayle/\" class=\"loc-link\">Hayle</a>\n        <a href=\"/attic-clearance-helston/\" class=\"loc-link\">Helston</a>\n        <a href=\"/attic-clearance-illogan/\" class=\"loc-link\">Illogan</a>\n        <a href=\"/attic-clearance-indian-queens/\" class=\"loc-link\">Indian Queens</a>\n        <a href=\"/attic-clearance-kelly-bray/\" class=\"loc-link\">Kelly Bray</a>\n        <a href=\"/attic-clearance-kilkhampton/\" class=\"loc-link\">Kilkhampton</a>\n        <a href=\"/attic-clearance-kingsand/\" class=\"loc-link\">Kingsand</a>\n        <a href=\"/attic-clearance-landrake/\" class=\"loc-link\">Landrake</a>\n        <a href=\"/attic-clearance-lanivet/\" class=\"loc-link\">Lanivet</a>\n        <a href=\"/attic-clearance-lanner/\" class=\"loc-link\">Lanner</a>\n        <a href=\"/attic-clearance-launceston/\" class=\"loc-link\">Launceston</a>\n        <a href=\"/attic-clearance-lelant/\" class=\"loc-link\">Lelant</a>\n        <a href=\"/attic-clearance-liskeard/\" class=\"loc-link\">Liskeard</a>\n        <a href=\"/attic-clearance-lizard/\" class=\"loc-link\">Lizard</a>\n        <a href=\"/attic-clearance-longrock/\" class=\"loc-link\">Longrock</a>\n        <a href=\"/attic-clearance-looe/\" class=\"loc-link\">Looe</a>\n        <a href=\"/attic-clearance-lostwithiel/\" class=\"loc-link\">Lostwithiel</a>\n        <a href=\"/attic-clearance-madron/\" class=\"loc-link\">Madron</a>\n        <a href=\"/attic-clearance-marazion/\" class=\"loc-link\">Marazion</a>\n        <a href=\"/attic-clearance-marhamchurch/\" class=\"loc-link\">Marhamchurch</a>\n        <a href=\"/attic-clearance-mawgan/\" class=\"loc-link\">Mawgan</a>\n        <a href=\"/attic-clearance-mawnan-smith/\" class=\"loc-link\">Mawnan Smith</a>\n        <a href=\"/attic-clearance-menheniot/\" class=\"loc-link\">Menheniot</a>\n        <a href=\"/attic-clearance-mevagissey/\" class=\"loc-link\">Mevagissey</a>\n        <a href=\"/attic-clearance-millbrook/\" class=\"loc-link\">Millbrook</a>\n        <a href=\"/attic-clearance-mount-hawke/\" class=\"loc-link\">Mount Hawke</a>\n        <a href=\"/attic-clearance-mousehole/\" class=\"loc-link\">Mousehole</a>\n        <a href=\"/attic-clearance-mullion/\" class=\"loc-link\">Mullion</a>\n        <a href=\"/attic-clearance-mylor-bridge/\" class=\"loc-link\">Mylor Bridge</a>\n        <a href=\"/attic-clearance-nanpean/\" class=\"loc-link\">Nanpean</a>\n        <a href=\"/attic-clearance-newlyn/\" class=\"loc-link\">Newlyn</a>\n        <a href=\"/attic-clearance-newquay/\" class=\"loc-link\">Newquay</a>\n        <a href=\"/attic-clearance-padstow/\" class=\"loc-link\">Padstow</a>\n        <a href=\"/attic-clearance-pelynt/\" class=\"loc-link\">Pelynt</a>\n        <a href=\"/attic-clearance-pendeen/\" class=\"loc-link\">Pendeen</a>\n        <a href=\"/attic-clearance-penpol/\" class=\"loc-link\">Penpol</a>\n        <a href=\"/attic-clearance-penryn/\" class=\"loc-link\">Penryn</a>\n        <a href=\"/attic-clearance-pensilva/\" class=\"loc-link\">Pensilva</a>\n        <a href=\"/attic-clearance-penwith/\" class=\"loc-link\">Penwith</a>\n   